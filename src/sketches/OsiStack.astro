---
// Esboço: the 7-layer OSI stack for the bonus networking Lesson, bound to
// aws/0006. Each layer is framed as a question; the two that decide the load
// balancer (L7 → ALB, L4 → NLB) are `hot`. On rails (ADR 0002/0003): scoped
// <style> + tokens, no script/network, offline-safe.
export interface OsiLayer {
  /** Layer number, 7 down to 1. */
  n: number;
  /** Layer name, e.g. "Aplicação". */
  name: string;
  /** The question the layer answers. */
  question: string;
  /** Protocols / AWS examples. */
  examples: string;
  /** Optional load-balancer tag, e.g. "ALB". */
  tag?: string;
  /** Highlights the layer (the two that matter for load balancing). */
  hot?: boolean;
}

interface Props {
  layers?: OsiLayer[];
}

const {
  layers = [
    {
      n: 7,
      name: "Aplicação",
      tag: "ALB",
      hot: true,
      question: '"Qual protocolo da aplicação e o que o usuário quer?"',
      examples: "HTTP/HTTPS, DNS, SMTP, SSH · AWS: ALB, API Gateway, CloudFront, Route 53",
    },
    {
      n: 6,
      name: "Apresentação",
      question: '"Em que formato? Cifrado? Comprimido?"',
      examples: "TLS/SSL, codificação (UTF-8), JPEG · AWS: certificados via ACM (HTTPS)",
    },
    {
      n: 5,
      name: "Sessão",
      question: '"Quem abre, mantém e fecha a conversa?"',
      examples: "Controle de diálogo (na prática, quase sempre fundida no app)",
    },
    {
      n: 4,
      name: "Transporte",
      tag: "NLB",
      hot: true,
      question: '"Entrega confiável ou rápida? Para qual porta/processo?"',
      examples: "TCP (confiável) vs UDP (rápido) + portas · AWS: NLB, Security Groups, NACLs",
    },
    {
      n: 3,
      name: "Rede",
      question: '"Por qual rota chego ao destino, entre redes diferentes?"',
      examples: "IP, roteamento, routers · AWS: VPC, sub-redes, route tables",
    },
    {
      n: 2,
      name: "Enlace (Data Link)",
      question: '"Como entrego ao próximo salto no mesmo segmento?"',
      examples: "MAC, switches, Ethernet, Wi-Fi, ARP · AWS: abstraído",
    },
    {
      n: 1,
      name: "Física",
      question: '"Como bits viram sinais no mundo real?"',
      examples: "Cabos, fibra, rádio, voltagem · AWS: hardware do data center (você nunca toca)",
    },
  ],
} = Astro.props;
---

<div class="osi">
  {
    layers.map((layer) => (
      <div
        class:list={["osi__layer", layer.hot && "osi__layer--hot"]}
        data-layer
        data-hot={layer.hot ? "true" : "false"}
      >
        <span class="osi__n">{layer.n}</span>
        <div class="osi__body">
          <span class="osi__name">
            {layer.name}
            {layer.tag && <span class="osi__tag">{layer.tag}</span>}
          </span>
          <div class="osi__q">{layer.question}</div>
          <div class="osi__ex">{layer.examples}</div>
        </div>
      </div>
    ))
  }
</div>

<style>
  .osi {
    border: 2px dashed var(--line-strong);
    border-radius: 14px;
    padding: 16px;
    margin: 18px 0;
    background: var(--soft);
  }
  .osi__layer {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    padding: 11px 14px;
    margin: 7px 0;
    background: var(--card);
  }
  .osi__layer--hot {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-soft) inset;
  }
  .osi__n {
    flex: 0 0 42px;
    font-weight: 700;
    color: #fff;
    background: var(--muted);
    border-radius: 7px;
    text-align: center;
    padding: 6px 0;
    font-size: 13px;
  }
  .osi__layer--hot .osi__n {
    background: var(--accent-deep);
  }
  .osi__body {
    flex: 1;
    min-width: 0;
    font-size: 13px;
  }
  .osi__name {
    font-weight: 700;
    color: var(--aws);
    font-size: 14px;
  }
  .osi__tag {
    display: inline-block;
    font-size: 10.5px;
    font-weight: 700;
    color: #fff;
    background: var(--accent-deep);
    border-radius: 5px;
    padding: 1px 6px;
    margin-left: 6px;
    vertical-align: middle;
  }
  .osi__q {
    color: var(--accent-deep);
    font-style: italic;
    font-size: 12.5px;
    margin: 1px 0 3px;
  }
  .osi__ex {
    color: var(--muted);
    font-size: 12.5px;
  }
</style>
