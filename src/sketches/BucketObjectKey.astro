---
// Esboço: the bucket → objeto → key diagram for the S3 Lesson — the first real
// Esboço. An Esboço is a one-off Component, authored by the Desenvolvedor for a
// single Aula; it lives in src/sketches/ (not the Catalog) and is bound to the
// Lesson via the sketch registry, so the Professor writes <BucketObjectKey /> in
// the MDX with no import — exactly like a Catalog Component, but scoped to this
// one Aula and not advertised in the guide. On rails (ADR 0002/0003): scoped
// <style> + design tokens, no external libs/CDN/network, so the PWA stays
// offline. A faithful static reproduction of the hand-written diagram.
export interface S3Object {
  /** Leading glyph for the row, e.g. "📄". */
  icon: string;
  /** The object's key within the bucket, e.g. "faturas/2026/nf.pdf". */
  key: string;
  /** Right-aligned caption, e.g. "objeto · 240 KB + metadados". */
  meta: string;
}

interface Props {
  bucket?: string;
  objects?: S3Object[];
}

const {
  bucket = "caravela-uploads-prod",
  objects = [
    { icon: "📄", key: "faturas/2026/06/nf-1837.pdf", meta: "objeto · 240 KB + metadados" },
    { icon: "🖼️", key: "avatars/user-42.png", meta: "objeto · 18 KB + metadados" },
  ],
} = Astro.props;
---

<figure class="bok" data-sketch="bucket-object-key">
  <div class="bok__bucket">
    <div class="bok__bucket-head">
      🪣 <code class="bok__bucket-name">{bucket}</code>
      <span class="bok__badge">nome único no mundo</span>
      <span class="bok__badge bok__badge--region">vive em 1 região</span>
    </div>
    {
      objects.map((o) => (
        <div class="bok__obj">
          <span class="bok__obj-icon" aria-hidden="true">
            {o.icon}
          </span>
          <span class="bok__key">{o.key}</span>
          <span class="bok__meta">{o.meta}</span>
        </div>
      ))
    }
  </div>
  <figcaption class="bok__note">
    A "/" na key é só <b>convenção visual</b> (prefixo). Não existe pasta de
    verdade — o namespace é <b>plano</b>.
  </figcaption>
</figure>

<style>
  .bok {
    border: 2px dashed var(--line-strong);
    border-radius: 14px;
    padding: 18px;
    margin: 18px 0;
    background: var(--soft);
  }
  .bok__bucket {
    border: 1.5px solid var(--aws);
    border-radius: 10px;
    padding: 12px 14px;
    background: var(--card);
  }
  .bok__bucket-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    color: var(--aws);
  }
  .bok__bucket-name {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 1px 6px;
    font-size: 0.9em;
  }
  .bok__badge {
    font-size: 10.5px;
    font-weight: 700;
    color: #fff;
    background: var(--accent-deep);
    border-radius: 5px;
    padding: 1px 7px;
  }
  .bok__badge--region {
    background: var(--info);
  }
  .bok__obj {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 8px 0 0;
    padding: 8px 11px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--soft);
    font-size: 13px;
  }
  .bok__key {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12.5px;
    color: var(--info);
  }
  .bok__meta {
    margin-left: auto;
    font-size: 12px;
    color: var(--muted);
  }
  .bok__note {
    margin: 12px 4px 0;
    font-size: 12.5px;
    color: var(--muted);
  }
</style>
