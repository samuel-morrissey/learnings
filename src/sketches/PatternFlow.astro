---
// Esboço: a labeled flow of nodes for the "5 workflow patterns" Lesson, bound to
// claude/0002 and reused once per pattern. A stage is either a single node or a
// vertical group of nodes (a branch / fan-out); stages are joined by arrows. Node
// variants map to the on-brand treatments: `alt` = accent (orchestrator/
// aggregator), `gray` = muted (optional / gate). On rails (ADR 0002/0003):
// scoped <style> + tokens, no script/network, offline-safe.
export interface FlowNode {
  label: string;
  /** Visual treatment: default (neutral), "alt" (accent), "gray" (muted). */
  variant?: "default" | "alt" | "gray";
}

// A stage is one or more nodes: a single node is the linear case, several nodes
// is a branch / fan-out (rendered as a column). `arrow` overrides the "→" that
// joins this stage to the previous one (e.g. "↺" for the evaluator loop).
export interface FlowStage {
  nodes: FlowNode[];
  arrow?: string;
}

interface Props {
  stages: FlowStage[];
}

const { stages } = Astro.props;
---

<div class="flow">
  {
    stages.map((stage, i) => (
      <>
        {i > 0 && (
          <span class="flow__arr" aria-hidden="true">
            {stage.arrow ?? "→"}
          </span>
        )}
        <span class:list={["flow__stage", stage.nodes.length > 1 && "flow__stage--col"]}>
          {stage.nodes.map((node) => (
            <span
              class:list={["flow__node", `flow__node--${node.variant ?? "default"}`]}
              data-node
              data-variant={node.variant ?? "default"}
            >
              {node.label}
            </span>
          ))}
        </span>
      </>
    ))
  }
</div>

<style>
  .flow {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin: 14px 0;
    font-size: 12.5px;
  }
  .flow__stage {
    display: inline-flex;
    gap: 6px;
  }
  .flow__stage--col {
    flex-direction: column;
  }
  .flow__node {
    background: var(--info-bg);
    border: 1px solid var(--line-strong);
    color: var(--info);
    border-radius: 7px;
    padding: 6px 10px;
    font-weight: 600;
    white-space: nowrap;
  }
  .flow__node--alt {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--accent-deep);
  }
  .flow__node--gray {
    background: var(--soft);
    border-color: var(--line);
    color: var(--muted);
  }
  .flow__arr {
    color: var(--muted);
    font-weight: 700;
  }
</style>
