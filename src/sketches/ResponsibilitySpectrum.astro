---
// Esboço: the shared-responsibility spectrum for the IaaS/PaaS/SaaS Lesson, bound
// to aws/0002. Each row is a service model; the stack of layers is coloured by
// *who* manages it — the top `owned` layers are yours, the rest are the
// provider's. Going down the rows, fewer layers are yours, which is the whole
// point. On rails (ADR 0002/0003): scoped <style> + tokens, no script/network.
export interface SpectrumRow {
  /** Model name, e.g. "IaaS". */
  model: string;
  /** Expansion, e.g. "Infra como serviço". */
  sub: string;
  /** How many of the top layers the customer manages. */
  owned: number;
}

interface Props {
  /** Layer names, top (closest to the app) to bottom (data center). */
  layers?: string[];
  rows?: SpectrumRow[];
}

const {
  layers = [
    "Aplicação",
    "Runtime / SO",
    "Rede / config",
    "Servidores físicos",
    "Data center",
  ],
  rows = [
    { model: "IaaS", sub: "Infra como serviço", owned: 3 },
    { model: "PaaS", sub: "Plataforma como serviço", owned: 1 },
    { model: "SaaS", sub: "Software como serviço", owned: 0 },
  ],
} = Astro.props;
---

<div class="spectrum">
  <div class="spectrum__legend">
    <span>◀ Mais controle e trabalho seu</span><span>Mais conveniência ▶</span>
  </div>
  {
    rows.map((row) => (
      <div class="spectrum__row" data-spectrum-row>
        <div class="spectrum__label">
          {row.model}
          <small>{row.sub}</small>
        </div>
        <div class="spectrum__stack">
          {layers.map((layer, i) => {
            const owner = i < row.owned ? "you" : "aws";
            return (
              <div
                class:list={["spectrum__seg", `spectrum__seg--${owner}`]}
                data-owner={owner}
              >
                {layer}
                {owner === "you" && <span class="spectrum__tag"> (você)</span>}
              </div>
            );
          })}
        </div>
      </div>
    ))
  }
  <p class="spectrum__caption">
    Laranja = <b>sua</b> responsabilidade · cinza = <b>AWS/fornecedor</b>. Quanto
    mais desce, menos você gerencia.
  </p>
</div>

<style>
  .spectrum {
    margin: 18px 0;
  }
  .spectrum__legend {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .spectrum__row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 10px;
    align-items: center;
    margin: 10px 0;
  }
  .spectrum__label {
    font-weight: 800;
    color: var(--aws);
    font-size: 14px;
  }
  .spectrum__label small {
    display: block;
    font-weight: 400;
    color: var(--muted);
    font-size: 11.5px;
  }
  .spectrum__stack {
    display: flex;
    gap: 4px;
  }
  .spectrum__seg {
    flex: 1;
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    padding: 8px 4px;
    border-radius: 6px;
    color: #fff;
  }
  .spectrum__seg--you {
    background: var(--accent);
  }
  .spectrum__seg--aws {
    background: var(--line-strong);
  }
  .spectrum__tag {
    font-weight: 400;
    opacity: 0.85;
  }
  .spectrum__caption {
    font-size: 13px;
    color: var(--muted);
    margin: 8px 0 0;
  }
  @media (max-width: 560px) {
    .spectrum__row {
      grid-template-columns: 1fr;
    }
  }
</style>
