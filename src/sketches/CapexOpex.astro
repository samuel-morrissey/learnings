---
// Esboço: the CapEx → OpEx contrast for the "O que é a nuvem" Lesson. A one-off
// Component (ADR 0002/0003) bound to aws/0001 via the sketch registry, so the
// Professor writes <CapexOpex /> with no import. Two labeled cards, each with a
// lead and the bullets that justify it — richer than CompareCards (a single
// description line), which is why it lives as an Esboço. On rails: scoped <style>
// + design tokens, no script/CDN/network, so the PWA stays offline.
export interface SpendModel {
  /** Eyebrow tag, e.g. "🏢 Modelo antigo — CapEx". */
  tag: string;
  /** The model name, e.g. "CapEx". */
  title: string;
  /** One-line framing of the model. */
  lead: string;
  /** The bullets that characterize it. */
  points: string[];
  /** Marks the recommended / cloud model. */
  highlight?: boolean;
}

interface Props {
  models?: SpendModel[];
}

const {
  models = [
    {
      tag: "🏢 Modelo antigo — CapEx",
      title: "CapEx",
      lead: "Você compra servidores antes de saber quanto vai usar. Gasto fixo e adiantado (Capital Expenditure).",
      points: [
        "Investimento alto na frente",
        "Adivinha a capacidade (erra para mais ou para menos)",
        "Semanas/meses para subir algo novo",
      ],
    },
    {
      tag: "☁️ Modelo da nuvem — OpEx",
      title: "OpEx",
      lead: "Você paga conforme usa. Gasto variável e operacional (Operational Expenditure).",
      points: [
        "Zero investimento adiantado",
        "Capacidade sob demanda (sobe e desce)",
        "Minutos para subir algo novo",
      ],
      highlight: true,
    },
  ],
} = Astro.props;
---

<div class="capex" role="list">
  {
    models.map((m) => (
      <div
        class:list={["capex__card", m.highlight && "capex__card--highlight"]}
        role="listitem"
        data-sketch-card
        data-highlight={m.highlight ? "true" : "false"}
      >
        <div class="capex__tag">{m.tag}</div>
        <div class="capex__title">{m.title}</div>
        <p class="capex__lead">{m.lead}</p>
        <ul class="capex__points">
          {m.points.map((p) => (
            <li>{p}</li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  .capex {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 18px 0;
  }
  .capex__card {
    border: 1.5px solid var(--line);
    border-radius: 12px;
    padding: 16px 18px;
    background: var(--card);
  }
  .capex__card--highlight {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-soft) inset;
  }
  .capex__tag {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }
  .capex__card--highlight .capex__tag {
    color: var(--ok);
  }
  .capex__title {
    font-weight: 800;
    color: var(--aws);
    font-size: 16px;
    margin-top: 2px;
  }
  .capex__lead {
    font-size: 13.5px;
    color: var(--ink);
    margin: 6px 0 0;
  }
  .capex__points {
    margin: 8px 0 0;
    padding-left: 18px;
    font-size: 13px;
    color: var(--muted);
  }
  .capex__points li {
    margin: 3px 0;
  }
  @media (max-width: 560px) {
    .capex {
      grid-template-columns: 1fr;
    }
  }
</style>
