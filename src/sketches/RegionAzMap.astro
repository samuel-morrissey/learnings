---
// Esboço: the nested geography diagram for the Regions/AZs Lesson, bound to
// aws/0003. Renders a Region box that contains Availability Zones, each holding
// one or more data centers — the "caixas dentro de caixas" hierarchy. On rails
// (ADR 0002/0003): scoped <style> + tokens, no script/network, offline-safe.
export interface Az {
  /** AZ label, e.g. "AZ-a". */
  name: string;
  /** How many data centers the AZ holds. */
  dcs: number;
}

interface Props {
  region?: { code: string; label: string };
  azs?: Az[];
  note?: string;
}

const {
  region = { code: "sa-east-1", label: "São Paulo 🇧🇷" },
  azs = [
    { name: "AZ-a", dcs: 2 },
    { name: "AZ-b", dcs: 1 },
    { name: "AZ-c", dcs: 2 },
  ],
  note = "Cada AZ = um ou mais data centers isolados (energia, refrigeração e rede próprios), mas conectados às outras AZs da região por links de baixa latência.",
} = Astro.props;
---

<div class="geo">
  <div class="geo__head">
    <span class="geo__badge">REGIÃO</span>
    <code class="geo__code">{region.code}</code> · {region.label}
  </div>
  <div class="geo__azs">
    {
      azs.map((az) => (
        <div class="geo__az" data-az>
          <div class="geo__az-name">{az.name}</div>
          <div class="geo__dcs">
            {Array.from({ length: az.dcs }).map(() => (
              <span class="geo__dc" data-dc>
                DC
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
  <p class="geo__note">{note}</p>
</div>

<style>
  .geo {
    border: 2px dashed var(--line-strong);
    border-radius: 14px;
    padding: 16px;
    margin: 18px 0;
    background: var(--soft);
  }
  .geo__head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-weight: 800;
    color: var(--aws);
    font-size: 14px;
    margin-bottom: 10px;
  }
  .geo__badge {
    background: var(--aws);
    color: #fff;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 999px;
  }
  .geo__code {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 1px 6px;
    font-size: 0.9em;
  }
  .geo__azs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .geo__az {
    background: var(--card);
    border: 1.5px solid var(--accent);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }
  .geo__az-name {
    font-weight: 700;
    color: var(--accent-deep);
    font-size: 13px;
  }
  .geo__dcs {
    margin-top: 6px;
  }
  .geo__dc {
    display: inline-block;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1px 5px;
    margin: 2px;
    font-size: 11px;
    color: var(--muted);
  }
  .geo__note {
    font-size: 12px;
    color: var(--muted);
    margin: 10px 0 0;
  }
  @media (max-width: 560px) {
    .geo__azs {
      grid-template-columns: 1fr;
    }
  }
</style>
