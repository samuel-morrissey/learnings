---
// Esboço: the classic elastic web architecture for the Auto Scaling Lesson,
// bound to aws/0005. Traffic flows from users into the load balancer, which fans
// out to EC2 instances spread across AZs, while Auto Scaling adjusts how many
// exist. On rails (ADR 0002/0003): scoped <style> + tokens, no script/network.
export interface ArchInstance {
  /** Instance label, e.g. "EC2". */
  label: string;
  /** Availability Zone caption, e.g. "AZ-a". */
  az: string;
}

interface Props {
  usersLabel?: string;
  elbLabel?: string;
  instances?: ArchInstance[];
  asgNote?: string;
}

const {
  usersLabel = "🌐 usuários",
  elbLabel = "Elastic Load Balancing",
  instances = [
    { label: "EC2", az: "AZ-a" },
    { label: "EC2", az: "AZ-b" },
    { label: "EC2", az: "AZ-c" },
  ],
  asgNote = "⤴ Auto Scaling adiciona/remove instâncias conforme a demanda (mín · desejado · máx)",
} = Astro.props;
---

<div class="arch">
  <div class="arch__users">{usersLabel}</div>
  <div class="arch__arrows" aria-hidden="true">↓</div>
  <div class="arch__elb">{elbLabel}</div>
  <div class="arch__arrows" aria-hidden="true">↙ ↓ ↘</div>
  <div class="arch__row">
    {
      instances.map((inst) => (
        <div class="arch__inst" data-inst>
          {inst.label}
          <span>{inst.az}</span>
        </div>
      ))
    }
  </div>
  <div class="arch__asg">{asgNote}</div>
</div>

<style>
  .arch {
    border: 2px dashed var(--line-strong);
    border-radius: 14px;
    padding: 18px;
    margin: 18px 0;
    background: var(--soft);
    text-align: center;
  }
  .arch__users {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .arch__elb {
    display: inline-block;
    background: var(--aws);
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 10px;
    margin: 6px 0;
  }
  .arch__arrows {
    color: var(--line-strong);
    font-size: 18px;
    letter-spacing: 18px;
    margin: 2px 0;
  }
  .arch__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 6px;
  }
  .arch__inst {
    background: var(--card);
    border: 1.5px solid var(--accent);
    border-radius: 10px;
    padding: 10px;
    font-size: 12.5px;
    color: var(--accent-deep);
    font-weight: 700;
  }
  .arch__inst span {
    display: block;
    font-weight: 400;
    color: var(--muted);
    font-size: 11px;
    margin-top: 3px;
  }
  .arch__asg {
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
    border-top: 1px dashed var(--line-strong);
    padding-top: 8px;
  }
  @media (max-width: 560px) {
    .arch__row {
      grid-template-columns: 1fr;
    }
  }
</style>
