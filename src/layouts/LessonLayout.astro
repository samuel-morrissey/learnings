---
import BaseLayout from "./BaseLayout.astro";
import Kicker from "../components/Kicker.astro";

// The Lesson shell: kicker + title + lead, then the rendered MDX body, then a
// link back to the Course. Prose styles target the slotted MDX content, so
// Markdown headings/tables/code inherit the product's identity via the tokens.
interface Props {
  title: string;
  domain: string;
  summary: string;
  estMinutes: number;
  courseTitle: string;
  courseHref: string;
}

const { title, domain, summary, estMinutes, courseTitle, courseHref } =
  Astro.props;
---

<BaseLayout title={title}>
  <header>
    <a class="back" href={courseHref}>← {courseTitle}</a>
  </header>

  <article class="card lesson">
    <Kicker>{domain} · ~{estMinutes} min</Kicker>
    <h1 class="lesson__title">{title}</h1>
    <p class="lesson__lead">{summary}</p>
    <slot />
  </article>

  <nav class="lesson__nav">
    <a class="back" href={courseHref}>← Voltar para {courseTitle}</a>
  </nav>
</BaseLayout>

<style is:global>
  .lesson {
    padding: 40px 44px;
    margin-bottom: 24px;
  }
  .lesson__title {
    font-size: 30px;
    line-height: 1.25;
    margin: 18px 0 6px;
    color: var(--aws);
  }
  .lesson__lead {
    font-size: 17px;
    color: var(--muted);
    margin: 12px 0;
  }

  /* Markdown prose inside the Lesson body */
  .lesson h2 {
    font-size: 21px;
    margin: 34px 0 10px;
    color: var(--aws);
    border-left: 4px solid var(--accent);
    padding-left: 12px;
  }
  .lesson h3 {
    font-size: 16px;
    margin: 22px 0 6px;
    color: var(--aws);
  }
  .lesson p {
    margin: 12px 0;
  }
  .lesson a {
    color: var(--accent-deep);
    text-decoration: none;
    border-bottom: 1px dotted var(--accent-deep);
  }
  .lesson code {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 1px 6px;
    font-size: 0.9em;
  }
  /* Blockquotes — the verbatim source quote (e.g. Anthropic) a Lesson leans on. */
  .lesson blockquote {
    margin: 16px 0;
    padding: 12px 18px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-left: 4px solid var(--line-strong);
    border-radius: 0 8px 8px 0;
    color: var(--ink);
    font-size: 14.5px;
  }
  .lesson blockquote > :first-child {
    margin-top: 0;
  }
  .lesson blockquote > :last-child {
    margin-bottom: 0;
  }
  .lesson blockquote cite {
    display: block;
    margin-top: 6px;
    font-size: 12.5px;
    color: var(--muted);
    font-style: normal;
  }
  .lesson pre {
    background: var(--aws);
    color: #fff;
    border-radius: 10px;
    padding: 14px 16px;
    overflow: auto;
  }
  .lesson pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }
  /* Wide comparison tables (IaaS/PaaS/SaaS, EC2 purchase models, …) scroll
     horizontally instead of overflowing the card on mobile. The `.table-scroll`
     wrapper is injected around every Markdown table by the rehype plugin in
     astro.config.mjs; the first column stays pinned so the row label is always
     visible while the rest of the row scrolls under it. */
  .lesson .table-scroll {
    margin: 16px 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
  }
  .lesson .table-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .lesson .table-scroll::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 3px;
  }
  .lesson table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .lesson th,
  .lesson td {
    border: 1px solid var(--line);
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
  }
  .lesson th {
    background: var(--aws);
    color: #fff;
  }
  .lesson tr:nth-child(even) td {
    background: var(--soft);
  }
  /* Sticky first column. Each pinned cell needs an opaque background so the
     scrolling cells don't show through underneath it. */
  .lesson th:first-child,
  .lesson td:first-child {
    position: sticky;
    left: 0;
  }
  .lesson td:first-child {
    background: var(--card);
  }
  .lesson tr:nth-child(even) td:first-child {
    background: var(--soft);
  }

  .lesson__nav {
    margin-top: 4px;
  }

  /* One breakpoint for the whole shell at 600px (matches BaseLayout's body
     padding). On mobile the card hugs the gutter: lateral padding drops to
     16px so the freed width goes to the content, not to nested padding. */
  @media (max-width: 599px) {
    .lesson {
      padding: 24px 16px;
    }
  }
</style>
