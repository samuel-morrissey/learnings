---
// The Kicker: the domain/lesson seal that opens a Lesson (e.g.
// "Domínio 3 — Storage · ~7 min"). Page chrome owned by the Plataforma — the
// Lesson shell renders it from Frontmatter. Deliberately NOT in the Catalog, so
// the Professor never authors the seal and it can never be duplicated in MDX.
interface Props {
  /** Brand tone of the pill; defaults to the AWS navy used today. */
  tone?: "aws" | "accent";
}

const { tone = "aws" } = Astro.props;
---

<span class:list={["kicker", `kicker--${tone}`]} data-tone={tone}>
  <span class="kicker__dot" aria-hidden="true"></span>
  <slot />
</span>

<style>
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 999px;
  }
  .kicker--aws {
    background: var(--aws);
  }
  .kicker--accent {
    background: var(--accent-deep);
  }
  .kicker__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
</style>
