---
// Sources: the Lesson's footnotes, with numbering *derived* — never hand-typed.
// Rendered as an ordered list, so the numbers (and the `r1`, `r2`… ids the prose
// links to) come from item order, not from the author. 1:1 with teach-v2's
// "Fontes" section.
export interface Source {
  /** Visible text of the source, e.g. "AWS — O que é o Amazon S3". */
  label: string;
  /** Optional link target. */
  href?: string;
}

interface Props {
  items: Source[];
  title?: string;
}

const { items, title = "Fontes" } = Astro.props;
---

<section class="sources" aria-label={title}>
  <h3 class="sources__title">{title}</h3>
  <ol class="sources__list">
    {
      items.map((source, i) => (
        <li id={`r${i + 1}`} class="sources__item">
          {source.href ? (
            <a class="ref" href={source.href}>
              {source.label}
            </a>
          ) : (
            source.label
          )}
        </li>
      ))
    }
  </ol>
</section>

<style>
  .sources {
    margin: 24px 0 0;
  }
  .sources__title {
    color: var(--aws);
    font-size: 16px;
    margin: 0 0 6px;
  }
  .sources__list {
    margin: 0;
    padding-left: 20px;
    font-size: 13px;
    color: var(--muted);
  }
  .sources__item {
    margin: 4px 0;
  }
  .sources__item .ref {
    color: var(--accent-deep);
    text-decoration: none;
    border-bottom: 1px dotted var(--accent-deep);
  }
</style>
