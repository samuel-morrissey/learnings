---
// The AskBox: the production task that closes a Lesson — "your turn to produce",
// where the learning actually happens. 1:1 with teach-v2's dark `.ask` box.
interface Props {
  title?: string;
}

const { title = "Sua vez de produzir" } = Astro.props;
---

<section class="ask" role="note" aria-label={title}>
  <h3 class="ask__title">👩‍🏫 {title}</h3>
  <div class="ask__body"><slot /></div>
</section>

<style>
  .ask {
    background: var(--aws);
    color: #fff;
    border-radius: 14px;
    padding: 22px 26px;
    margin: 24px 0;
  }
  .ask__title {
    color: #fff;
    margin: 0 0 8px;
    font-size: 16px;
  }
  .ask__body {
    color: #cdd8e3;
    font-size: 14.5px;
  }
  .ask__body > :first-child {
    margin-top: 0;
  }
  .ask__body > :last-child {
    margin-bottom: 0;
  }
  .ask__body :global(code) {
    background: rgba(255, 255, 255, 0.12);
    border: none;
    color: #fff;
    padding: 2px 7px;
    border-radius: 6px;
    font-size: 13px;
  }
</style>
