---
// Quiz: the first interactive island of the Catalog. Data-driven — the Pedagogo
// declares questions, alternatives, the correct answer and an explanation, and
// never writes JS. The interactivity lives scoped in this Component (a single
// bundled <script>, no global JS reopened in the Aula), preserving the
// lightweight, offline-friendly page. Picked by meaning, like every Component.
export interface QuizQuestion {
  /** The question text. */
  prompt: string;
  /** The alternatives, in display order. */
  options: string[];
  /** Zero-based index into `options` of the correct alternative. */
  answer: number;
  /** Shown as feedback once the question is answered. */
  explanation?: string;
}

interface Props {
  questions: QuizQuestion[];
  title?: string;
}

const { questions, title = "Teste rápido — feedback na hora" } = Astro.props;
const total = questions.length;
---

<section class="quiz" data-quiz data-total={total} aria-label={title}>
  <h3 class="quiz__title">✅ {title}</h3>
  {
    questions.map((q, qi) => (
      <div class="quiz__q" data-answer={String(q.answer)}>
        <div class="quiz__num">
          Questão {qi + 1} de {total}
        </div>
        <p class="quiz__prompt">{q.prompt}</p>
        <div class="quiz__opts" role="group" aria-label={`Questão ${qi + 1}`}>
          {q.options.map((opt, oi) => (
            <button
              type="button"
              class="quiz__opt"
              data-index={String(oi)}
              data-correct={oi === q.answer ? "true" : "false"}
            >
              {opt}
            </button>
          ))}
        </div>
        <p class="quiz__fb" data-explanation hidden>
          {q.explanation ?? ""}
        </p>
      </div>
    ))
  }
  <p class="quiz__score" data-score hidden></p>
</section>

<script>
  // Wires every Quiz on the page; each instance grades and scores on its own.
  for (const quiz of document.querySelectorAll<HTMLElement>("[data-quiz]")) {
    const questions = quiz.querySelectorAll<HTMLElement>(".quiz__q");
    const total = questions.length;
    const scoreEl = quiz.querySelector<HTMLElement>("[data-score]");
    let answered = 0;
    let correct = 0;

    questions.forEach((q) => {
      const answer = Number(q.dataset.answer);
      const opts = q.querySelectorAll<HTMLButtonElement>(".quiz__opt");
      const fb = q.querySelector<HTMLElement>("[data-explanation]");
      const exp = fb?.textContent?.trim() ?? "";

      opts.forEach((btn) => {
        btn.addEventListener("click", () => {
          if (q.dataset.done) return;
          q.dataset.done = "1";
          answered++;

          const picked = Number(btn.dataset.index);
          opts.forEach((b) => (b.disabled = true));
          opts[answer]?.classList.add("quiz__opt--correct");

          if (fb) fb.hidden = false;
          if (picked === answer) {
            correct++;
            if (fb) {
              fb.className = "quiz__fb quiz__fb--ok";
              fb.textContent = `✔️ Correto! ${exp}`.trimEnd();
            }
          } else {
            btn.classList.add("quiz__opt--wrong");
            if (fb) {
              fb.className = "quiz__fb quiz__fb--no";
              fb.textContent = `✗ Quase. ${exp}`.trimEnd();
            }
          }

          if (answered === total && scoreEl) {
            const msg =
              correct === total
                ? "🏆 Gabaritou!"
                : correct >= total - 1
                  ? "💪 Quase lá — reveja o ponto que escapou."
                  : "📚 Releia e tente de novo.";
            scoreEl.hidden = false;
            scoreEl.textContent = `Resultado: ${correct}/${total} — ${msg}`;
            scoreEl.scrollIntoView({ behavior: "smooth", block: "center" });
          }
        });
      });
    });
  }
</script>

<style>
  .quiz {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px 24px;
    margin: 20px 0;
  }
  .quiz__title {
    margin: 0 0 14px;
    font-size: 16px;
    color: var(--aws);
  }
  .quiz__q {
    margin-top: 18px;
  }
  .quiz__q:first-of-type {
    margin-top: 0;
  }
  .quiz__num {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }
  .quiz__prompt {
    font-weight: 600;
    font-size: 15.5px;
    margin: 6px 0 12px;
    color: var(--aws);
  }
  .quiz__opt {
    display: block;
    width: 100%;
    text-align: left;
    background: var(--card);
    border: 1.5px solid var(--line);
    border-radius: 10px;
    padding: 12px 14px;
    margin: 8px 0;
    font-size: 14.5px;
    font-family: inherit;
    color: var(--ink);
    cursor: pointer;
    transition: 0.15s;
  }
  .quiz__opt:hover:not(:disabled) {
    border-color: var(--accent);
    background: #fffaf3;
  }
  .quiz__opt:disabled {
    cursor: default;
  }
  .quiz__opt--correct {
    border-color: var(--ok);
    background: var(--ok-bg);
  }
  .quiz__opt--wrong {
    border-color: var(--danger);
    background: var(--danger-bg);
  }
  .quiz__fb {
    margin: 12px 0 0;
    padding: 12px 14px;
    border-radius: 10px;
    font-size: 14px;
  }
  .quiz__fb[hidden] {
    display: none;
  }
  .quiz__fb--ok {
    background: var(--ok-bg);
    color: #155f37;
  }
  .quiz__fb--no {
    background: var(--danger-bg);
    color: #8a1f2c;
  }
  .quiz__score {
    margin: 18px 0 0;
    font-weight: 700;
    color: var(--aws);
  }
  .quiz__score[hidden] {
    display: none;
  }
</style>
