---
// CompareCards: the parametrizable generalization of teach-v2's *triple cards*
// (e.g. bloco / arquivo / objeto). Data-driven by N options, so it is never tied
// to one specific case — the Pedagogo compares two, three or more side by side
// without writing bespoke CSS. One card may be `highlight`ed (the recommended /
// in-focus option), mapping to the on-brand accent treatment.
export interface CompareCard {
  /** The option's name, e.g. "Objeto". */
  label: string;
  /** Optional eyebrow tag, e.g. "S3 · object". */
  tag?: string;
  /** Optional one-line description of the option. */
  description?: string;
  /** Marks this card as the highlighted / in-focus option. */
  highlight?: boolean;
}

interface Props {
  cards: CompareCard[];
}

const { cards } = Astro.props;
---

<div class="compare" role="list">
  {
    cards.map((card) => (
      <div
        class:list={["compare__card", card.highlight && "compare__card--highlight"]}
        role="listitem"
        data-highlight={card.highlight ? "true" : "false"}
      >
        {card.tag && <div class="compare__tag">{card.tag}</div>}
        <div class="compare__label">{card.label}</div>
        {card.description && <div class="compare__desc">{card.description}</div>}
      </div>
    ))
  }
</div>

<style>
  .compare {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 18px 0;
  }
  .compare__card {
    flex: 1;
    min-width: 200px;
    border: 1.5px solid var(--line);
    border-radius: 12px;
    padding: 14px 16px;
    background: var(--card);
  }
  .compare__card--highlight {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-soft) inset;
  }
  .compare__tag {
    font-size: 11.5px;
    color: var(--accent-deep);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .compare__label {
    font-weight: 700;
    color: var(--aws);
    font-size: 14.5px;
    margin-top: 2px;
  }
  .compare__desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 6px;
  }
</style>
