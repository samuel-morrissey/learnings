---
// Nav: previous / next navigation at the foot of a Lesson, so the Student moves
// along the trail without returning to the index. 1:1 with teach-v2's `.nav`
// links. Both ends are optional — the first Lesson has no `prev`, the last no
// `next`. Each link carries its semantic rel so the relationship is in the markup.
export interface NavLink {
  href: string;
  label: string;
  /** Optional caption shown under the label. */
  sub?: string;
}

interface Props {
  prev?: NavLink;
  next?: NavLink;
}

const { prev, next } = Astro.props;
---

<nav class="nav" aria-label="Navegação entre Aulas">
  {
    prev && (
      <a class="nav__link" href={prev.href} rel="prev" data-rel="prev">
        <b>⬅️ {prev.label}</b>
        {prev.sub && <small>{prev.sub}</small>}
      </a>
    )
  }
  {
    next && (
      <a class="nav__link nav__link--next" href={next.href} rel="next" data-rel="next">
        <b>{next.label} ➡️</b>
        {next.sub && <small>{next.sub}</small>}
      </a>
    )
  }
</nav>

<style>
  .nav {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 18px 0 6px;
  }
  .nav__link {
    flex: 1;
    min-width: 200px;
    text-decoration: none;
    color: var(--aws);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 14px;
    background: var(--card);
  }
  .nav__link:hover {
    border-color: var(--accent);
    background: #fffaf3;
  }
  .nav__link--next {
    text-align: right;
  }
  .nav__link b {
    color: var(--accent-deep);
  }
  .nav__link small {
    display: block;
    color: var(--muted);
    font-weight: 400;
  }
</style>
