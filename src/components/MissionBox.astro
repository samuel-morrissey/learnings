---
// The MissionBox: the "why this Lesson matters" framing the Pedagogo opens with.
// 1:1 with teach-v2's `.mission` box — the 🎯 heading, the body, and an optional
// meta line (duration / prerequisite) via the `meta` slot. Picked by meaning, so
// the framing reads the same across every Course.
interface Props {
  title?: string;
}

const { title = "Por que esta Aula?" } = Astro.props;
---

<aside class="mission" role="note" aria-label={title}>
  <p class="mission__title">🎯 <strong>{title}</strong></p>
  <div class="mission__body"><slot /></div>
  {
    Astro.slots.has("meta") && (
      <p class="mission__meta">
        <slot name="meta" />
      </p>
    )
  }
</aside>

<style>
  .mission {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 16px 18px;
    font-size: 14.5px;
    margin: 20px 0;
  }
  .mission__title {
    margin: 0 0 6px;
  }
  .mission__title strong {
    color: var(--accent-deep);
  }
  .mission__body > :first-child {
    margin-top: 0;
  }
  .mission__body > :last-child {
    margin-bottom: 0;
  }
  .mission__meta {
    margin: 8px 0 0;
    color: var(--muted);
  }
</style>
