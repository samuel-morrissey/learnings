---
// The first Catalog Component. The Pedagogo picks a Callout by *meaning*
// (variant), never by markup or color. Variants map to the centralized status
// tokens, so every Callout is on-brand. Globally available in MDX (provided via
// the render `components` prop), so a Lesson uses <Callout> without importing.
interface Props {
  variant?: "info" | "warn" | "ok";
}

const { variant = "info" } = Astro.props;

const LABEL: Record<NonNullable<Props["variant"]>, string> = {
  info: "Nota",
  warn: "Atenção",
  ok: "Boa prática",
};

const ICON: Record<NonNullable<Props["variant"]>, string> = {
  info: "💡",
  warn: "⚠️",
  ok: "✅",
};
---

<aside
  class:list={["callout", `callout--${variant}`]}
  data-variant={variant}
  role="note"
  aria-label={LABEL[variant]}
>
  <span class="callout__icon" aria-hidden="true">{ICON[variant]}</span>
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 10px;
    border-left: 4px solid var(--info);
    background: var(--info-bg);
    border-radius: 8px;
    padding: 14px 16px;
    margin: 18px 0;
    font-size: 14.5px;
  }
  .callout__icon {
    flex: none;
    line-height: 1.5;
  }
  .callout__body {
    min-width: 0;
  }
  /* First/last children flush so the box hugs its content. */
  .callout__body > :first-child {
    margin-top: 0;
  }
  .callout__body > :last-child {
    margin-bottom: 0;
  }

  .callout--info {
    border-left-color: var(--info);
    background: var(--info-bg);
  }
  .callout--warn {
    border-left-color: var(--warn);
    background: var(--warn-bg);
  }
  .callout--ok {
    border-left-color: var(--ok);
    background: var(--ok-bg);
  }
</style>
