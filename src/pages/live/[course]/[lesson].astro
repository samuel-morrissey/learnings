---
// The SSR Lesson route: a Lesson rendered from Firestore per request. It reads
// the document through the thin Firestore adapter, compiles the stored `mdx` at
// runtime, and renders the full Preact Catalog by name — with the per-block
// fallback wired in, so an unknown Component, an Esboço not yet deployed, or
// invalid props degrade just their block instead of crashing the page (issue
// #24). The shell (LessonLayout/BaseLayout) stays `.astro`.
import LessonLayout from "../../../layouts/LessonLayout.astro";
import { readLesson, readCourseTitle } from "../../../lib/firestore";
import { renderAula } from "../../../lib/render-aula";
import { bundledSketches } from "../../../sketches/preact";
import "../../../styles/catalog.css";
import "../../../styles/sketches.css";

const { course, lesson } = Astro.params;

const record = await readLesson(course!, lesson!);
if (!record) {
  return new Response(`Aula não encontrada: ${course}/${lesson}`, {
    status: 404,
  });
}

// The human Course title lives on the parent `courses/{course}` doc, not the
// Lesson; fall back to the path id if it is missing.
const courseTitle = (await readCourseTitle(record.course)) ?? record.course;

// The render resolves Catalog Components by name internally; we hand it the
// Lesson's declared Esboço names and the deployed Esboço bundle so it can bind
// the ones it has and fall back on the ones still awaiting deploy.
const body = await renderAula(record.mdx, {
  esbocos: record.esbocos,
  sketches: bundledSketches,
});

const base = import.meta.env.BASE_URL;
---

<LessonLayout
  title={record.title}
  domain={record.domain}
  summary={record.summary}
  estMinutes={record.estMinutes}
  courseTitle={courseTitle}
  courseHref={`${base}courses/${record.course}/`}
>
  <Fragment set:html={body} />
</LessonLayout>

{/* The Quiz island's behaviour: a single framework-agnostic script that wires
    every `[data-quiz]` the rendered MDX emitted. Static markup comes from the
    Preact Quiz Component; this makes it interactive without Astro hydration,
    which runtime-rendered MDX can't use. */}
<script>import "../../../lib/quiz-client.ts";</script>
