---
// SSR (issue #25): the hub lists Courses from Firestore per request — no build,
// no filesystem. Every Course (with at least one Lesson) and its Lesson count.
import BaseLayout from "../layouts/BaseLayout.astro";
import { readSiteModel } from "../lib/firestore";

const { courses } = await readSiteModel();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Learnings">
  <header>
    <h1>Learnings</h1>
  </header>
  <main>
    <ul class="list card">
      {
        courses.map((course) => (
          <li>
            <a href={`${base}courses/${course.name}/`}>
              <span class="title">{course.title}</span>
              <span class="meta">
                {`· ${course.lessonCount} ${course.lessonCount === 1 ? "aula" : "aulas"}`}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
