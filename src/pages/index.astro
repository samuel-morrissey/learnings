---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildSiteModel } from "../lib/site-model";
import { COURSES_DIR } from "../lib/paths";

// The hub: every Course (with at least one MDX Lesson) and its Lesson count.
const { courses } = buildSiteModel(COURSES_DIR);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Learnings">
  <header>
    <h1>Learnings</h1>
  </header>
  <main>
    <ul class="list card">
      {
        courses.map((course) => (
          <li>
            <a href={`${base}courses/${course.name}/`}>
              <span class="title">{course.title}</span>
              <span class="meta">
                {`· ${course.lessonCount} ${course.lessonCount === 1 ? "aula" : "aulas"}`}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
