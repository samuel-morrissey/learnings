---
// SSR (issue #25): a Course page lists its Lessons (ordered by `order`) from
// Firestore per request. The human title comes from the Course document field.
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readCourse } from "../../../lib/firestore";

const { course: courseName } = Astro.params;
const course = await readCourse(courseName!);
if (!course) {
  return new Response(`Curso não encontrado: ${courseName}`, { status: 404 });
}

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={course.title}>
  <header>
    <a class="back" href={base}>← Learnings</a>
    <h1>{course.title}</h1>
  </header>
  <main>
    <ol class="list card">
      {
        course.lessons.map((lesson) => (
          <li>
            <a href={`${base}courses/${course.name}/${lesson.slug}/`}>
              {lesson.title}
            </a>
          </li>
        ))
      }
    </ol>
  </main>
</BaseLayout>
