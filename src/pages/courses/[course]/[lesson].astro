---
// Static during the migration: the current Lessons render from `.mdx` files at
// build time. The Firestore-backed SSR Lesson lives at /live/[course]/[lesson].
export const prerender = true;

import { getEntry, render } from "astro:content";
import LessonLayout from "../../../layouts/LessonLayout.astro";
import { catalog } from "../../../components/catalog";
import { sketchesFor } from "../../../sketches/registry";
import { readSiteModelFromFs } from "../../../lib/site-model-fs";
import { COURSES_DIR } from "../../../lib/paths";

export function getStaticPaths() {
  const { courses } = readSiteModelFromFs(COURSES_DIR);
  return courses.flatMap((course) =>
    course.lessons.map((lesson) => ({
      params: { course: course.name, lesson: lesson.slug },
      props: { lesson, courseTitle: course.title },
    }))
  );
}

const { lesson, courseTitle } = Astro.props;
const base = import.meta.env.BASE_URL;

const lessonId = `${lesson.course}/${lesson.slug}`;
const entry = await getEntry("lessons", lessonId);
if (!entry) {
  throw new Error(`Lesson entry not found: ${lessonId}`);
}
const { Content } = await render(entry);
---

<LessonLayout
  title={lesson.title}
  domain={lesson.domain}
  summary={lesson.summary}
  estMinutes={lesson.estMinutes}
  courseTitle={courseTitle}
  courseHref={`${base}courses/${lesson.course}/`}
>
  {/* The whole Catalog is provided here, so the MDX uses any Component
      (<Callout>, <MissionBox>, <CompareCards>…) without importing. Plus this
      Lesson's Esboços, scoped to it alone via the registry — never global. */}
  <Content components={{ ...catalog, ...sketchesFor(lessonId) }} />
</LessonLayout>
