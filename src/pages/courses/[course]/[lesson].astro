---
import { getEntry, render } from "astro:content";
import LessonLayout from "../../../layouts/LessonLayout.astro";
import Callout from "../../../components/Callout.astro";
import { buildSiteModel } from "../../../lib/site-model";
import { COURSES_DIR } from "../../../lib/paths";

export function getStaticPaths() {
  const { courses } = buildSiteModel(COURSES_DIR);
  return courses.flatMap((course) =>
    course.lessons.map((lesson) => ({
      params: { course: course.name, lesson: lesson.slug },
      props: { lesson, courseTitle: course.title },
    }))
  );
}

const { lesson, courseTitle } = Astro.props;
const base = import.meta.env.BASE_URL;

const entry = await getEntry("lessons", `${lesson.course}/${lesson.slug}`);
if (!entry) {
  throw new Error(`Lesson entry not found: ${lesson.course}/${lesson.slug}`);
}
const { Content } = await render(entry);
---

<LessonLayout
  title={lesson.title}
  domain={lesson.domain}
  summary={lesson.summary}
  estMinutes={lesson.estMinutes}
  courseTitle={courseTitle}
  courseHref={`${base}courses/${lesson.course}/`}
>
  {/* Callout is provided here, so the MDX uses <Callout> without importing. */}
  <Content components={{ Callout }} />
</LessonLayout>
